# Environment Configuration
# Copy this file to .env and update values for your environment

# Application
APP_NAME=Play House Management System
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://playhouse:playhouse123@localhost:5432/playhouse_db
# For local development without Docker:
# DATABASE_URL=postgresql://localhost/playhouse_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production-please-use-strong-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost:5173"]

# Business Settings
BUSINESS_NAME=Play House Gaming Center
CURRENCY=SAR
DEFAULT_HOURLY_RATE=50.0
TAX_RATE=0.15

# Email (for future use)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@playhouse.local

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/playhouse.log

# AWS S3 (for future use)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=playhouse-bucket
# AWS_REGION=eu-west-1

# Payment Gateway (for future use)
# STRIPE_API_KEY=sk_live_...
# PAYPAL_CLIENT_ID=...

# Analytics (for future use)
# GOOGLE_ANALYTICS_ID=UA-...

# Feature Flags
ENABLE_LOYALTY_SYSTEM=true
ENABLE_REPORTS=true
ENABLE_EMAIL_NOTIFICATIONS=false
